<%- include("partials/header.ejs") %> 
<head>
    <title> Edit Post Page</title>
    <link rel="stylesheet" href="/styles/styles.css">
    <!-- <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous"> -->
</head>
<body>
  <div class="container">
    <div class="col">
        <h1>Edit Post</h1>
        <!-- <form action="/read_all/edit/< %= index %>?_method=PUT" method="POST"> -->
        <form  action="/read_all/<%= post.id %>/allow-changes" method="POST">
            <input type="hidden" name="_method" value="PUT">
            <div class="mb-3">
                <label for="title" class="form-label">Title:</label>
                <input type="text" class="form-control" id="title" name="NewPostTitle" value="<%= post.title %>"
                    required>
            </div>
            <br />
            <div class="mb-3">
                <label for="content" class="form-label">Content:</label>
                <textarea class="form-control" id="content" name="NewPostContent" rows="10" required><%= post.content %></textarea>
            </div>
            <br />
            <div>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>
</div>
</body>
<%- include("partials/footer.ejs") %>