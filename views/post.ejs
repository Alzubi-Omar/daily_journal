<%- include('partials/header') %>

<head>
  <title>Full Post Read</title>
</head>
<body>
  <div class="container">
    <!-- edit/delete post -->
    <div class="float-posright">
      <% if(locals.post) { %>
      <a href="/read_all/<%=post.id%>/edit"
        ><button class="btn btn-primary">Edit</button></a
      >

      <form
        action="/read_all/<%=post.id%>/delete"
        method="post"
        style="display: inline"
      >
        <input type="hidden" name="_method" value="DELETE" />
        <button type="submit" class="btn btn-danger">Delete</button>
      </form>
    </div>
    <!-- Post title and content -->
    <div class="bg-body-secondary">
      <h2><%= post.title %></h2>
      <p><%= post.content %></p>
    </div>
    <br />
    <!-- read_all -->
    <div class="go-back">
      <button><a href="/read_all">Read all</a></button>
    </div>
    <% } %>
  </div>
</body>

<%- include('partials/footer') %>
